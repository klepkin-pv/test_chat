NEXT_PUBLIC_SOCKET_URL=http://localhost:4000

# ===== DOCKER + NGINX (через прокси) =====
# Используй эти настройки при запуске через Docker:
# PORT=4000
# CLIENT_URL=http://localhost:5175
# MONGODB_URI=mongodb://mongodb:27017/chatreal
# REDIS_URL=redis://redis:6379
# NEXT_PUBLIC_API_URL=http://localhost:5175/api/chat
# NEXT_PUBLIC_SOCKET_URL=http://localhost:5175

# ===== PRODUCTION =====
# JWT_SECRET=generate_strong_random_secret_here