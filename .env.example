# Shared app addresses and ports
APP_PROTOCOL=http
APP_HOST=localhost
PUBLIC_ORIGIN=
NGINX_PORT=5176
FRONTEND_PORT=5175
MONGODB_PORT=27018
REDIS_PORT=6380

# Backend
PORT=4000
CLIENT_URL=http://localhost:5176
MONGODB_URI=mongodb://mongodb:27017/chatreal
REDIS_URL=redis://redis:6379
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
ALLOWED_ORIGIN_PATTERNS=*.zrok.io

# Optional admin bootstrap on container start
AUTO_CREATE_ADMIN=true
ADMIN_USERNAME=admin
ADMIN_DISPLAY_NAME=Батя
ADMIN_EMAIL=
ADMIN_PASSWORD=123123

# Legacy frontend overrides (optional)
# Leave empty in most cases: frontend now auto-detects proxy vs direct backend.
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_SOCKET_URL=

# Web Push (VAPID)
# node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(k)"
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_EMAIL=mailto:admin@chatreal.app

# Example for nginx / reverse proxy
# PUBLIC_ORIGIN=https://worksource.share.zrok.io
# CLIENT_URL=https://worksource.share.zrok.io
